TELEGRAM_BOT_TOKEN=your_bot_token_here
SMMWIZ_API_KEY=your_smmwiz_api_key_here
ADMIN_TELEGRAM_IDS=123456789,987654321
DATABASE_URL=postgres://smm:changeme@localhost:5432/smm?sslmode=disable
MEGAPAY_API_KEY=your_megapay_api_key_here
MEGAPAY_EMAIL=your_megapay_account_email_here
BALANCE_ALERT_THRESHOLD=5.0

# Optional: numeric channel ID for public social proof posts (bot must be channel admin)
SOCIAL_PROOF_CHANNEL_ID=

# Optional: separate admin bot for live traffic tracking
# Create a new bot via @BotFather, set ADMIN_BOT_TOKEN to its token
# Set ADMIN_CHAT_ID to your personal Telegram user ID (get it from @userinfobot)
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=

# CORS origin for web frontend (e.g. https://innbucks.org)
FRONTEND_ORIGIN=https://innbucks.org
